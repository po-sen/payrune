# Copy this file to an untracked local env file and pass it with:
# docker compose --env-file path/to/your.env -f deployments/compose/compose.yaml up
#
# This file is a superset reference for:
# - the formal/mainnet-style compose path
# - the local development path in the same `deployments/compose/compose.yaml`
#
# `make up` still uses the checked-in development file
# `deployments/compose/compose.dev.env`.

DATABASE_URL=postgres://payrune:payrune@postgres:5432/payrune?sslmode=disable

# Bitcoin mainnet (formal/mainnet-style path)
BITCOIN_MAINNET_LEGACY_ENABLED=false
BITCOIN_MAINNET_LEGACY_XPUB=

BITCOIN_MAINNET_SEGWIT_ENABLED=false
BITCOIN_MAINNET_SEGWIT_XPUB=

BITCOIN_MAINNET_NATIVE_SEGWIT_ENABLED=false
BITCOIN_MAINNET_NATIVE_SEGWIT_XPUB=

BITCOIN_MAINNET_TAPROOT_ENABLED=false
BITCOIN_MAINNET_TAPROOT_XPUB=

BITCOIN_MAINNET_REQUIRED_CONFIRMATIONS=2
BITCOIN_MAINNET_RECEIPT_EXPIRES_AFTER=24h
BITCOIN_MAINNET_ESPLORA_URL=https://mempool.space/api
BITCOIN_MAINNET_ESPLORA_USER=
BITCOIN_MAINNET_ESPLORA_PASSWORD=
BITCOIN_MAINNET_ESPLORA_TIMEOUT=10s

# Bitcoin testnet4 (local development path)
# Kept disabled by default in this formal/mainnet-style example file.
BITCOIN_TESTNET4_LEGACY_ENABLED=false
BITCOIN_TESTNET4_LEGACY_XPUB=tpubDDoLYVq7AUqYP63QvYZxnxk1pCJnWDWdzu9w3BYTP9dJAX47xknZiEKUheaAahn6zBNT5ndCzY2x6MQ8iVj7QpFwuhm5bDF6Ggt3q1Rn2Qs

BITCOIN_TESTNET4_SEGWIT_ENABLED=false
BITCOIN_TESTNET4_SEGWIT_XPUB=tpubDCiGGQjmzt8kJU2yX3xQmiL39zKXJKzWDMC3cpoh6Q6VVF1asGd1Je99G72GFLq8t9oMiYPVbmdxwPgKsLspM7kFua2a4NqLQSwAirU2pB2

BITCOIN_TESTNET4_NATIVE_SEGWIT_ENABLED=false
BITCOIN_TESTNET4_NATIVE_SEGWIT_XPUB=tpubDCiB1iLoNxaaj4MTSk2DoTuwUpEfgm4E3vAcTnvG64rR1smhcEsoTeqNCB4af1XHGspgNfWBA3ccpXiwX5JtxwZMTFct6DQWzrKundqdwEq

BITCOIN_TESTNET4_TAPROOT_ENABLED=false
BITCOIN_TESTNET4_TAPROOT_XPUB=tpubDCEp3dYAyqnXrXPDSw4bhmj6cB6KmM2SkpDXzJWmQ595tPFobRSxhajfz7Yq5ZJvZaQ2qzQDWgaFiihSEQQJn12qtweLnveaA7FYLcpcF97

BITCOIN_TESTNET4_REQUIRED_CONFIRMATIONS=2
BITCOIN_TESTNET4_RECEIPT_EXPIRES_AFTER=24h
BITCOIN_TESTNET4_ESPLORA_URL=https://mempool.space/testnet4/api
BITCOIN_TESTNET4_ESPLORA_USER=
BITCOIN_TESTNET4_ESPLORA_PASSWORD=
BITCOIN_TESTNET4_ESPLORA_TIMEOUT=10s

# Ethereum mainnet (formal/mainnet-style path)
ETHEREUM_MAINNET_CREATE2_ENABLED=false
ETHEREUM_MAINNET_USDT_CREATE2_ENABLED=false

# Required when either Ethereum mainnet CREATE2 policy is enabled.
ETHEREUM_MAINNET_CREATE2_COLLECTOR_ADDRESS=
ETHEREUM_MAINNET_CREATE2_DERIVATION_KEY=

# Official Ethereum mainnet USDT asset reference. Required when
# ETHEREUM_MAINNET_USDT_CREATE2_ENABLED=true.
ETHEREUM_MAINNET_USDT_ASSET_REFERENCE=0xdAC17F958D2ee523a2206206994597C13D831ec7

ETHEREUM_MAINNET_REQUIRED_CONFIRMATIONS=12
ETHEREUM_MAINNET_RECEIPT_EXPIRES_AFTER=24h
ETHEREUM_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
ETHEREUM_MAINNET_RPC_USER=
ETHEREUM_MAINNET_RPC_PASSWORD=
ETHEREUM_MAINNET_RPC_TIMEOUT=10s

# Ethereum sepolia (local development path)
# Kept disabled by default in this formal/mainnet-style example file.
ETHEREUM_SEPOLIA_CREATE2_ENABLED=false
ETHEREUM_SEPOLIA_USDT_CREATE2_ENABLED=false

# Required when either Ethereum sepolia CREATE2 policy is enabled.
ETHEREUM_SEPOLIA_CREATE2_COLLECTOR_ADDRESS=0x43D06C10333861C8Ce5BeE0D61A291f31A126247
ETHEREUM_SEPOLIA_CREATE2_DERIVATION_KEY=0x132a4fb6dc5766792c7fe25f9d42d3c3079331715ffdf6e9ea1a8bfcfe378d75

# Tether WDK Sepolia USD₮ test-token contract. Required when
# ETHEREUM_SEPOLIA_USDT_CREATE2_ENABLED=true.
ETHEREUM_SEPOLIA_USDT_ASSET_REFERENCE=0xd077a400968890eacc75cdc901f0356c943e4fdb

ETHEREUM_SEPOLIA_REQUIRED_CONFIRMATIONS=12
ETHEREUM_SEPOLIA_RECEIPT_EXPIRES_AFTER=24h
ETHEREUM_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHEREUM_SEPOLIA_RPC_USER=
ETHEREUM_SEPOLIA_RPC_PASSWORD=
ETHEREUM_SEPOLIA_RPC_TIMEOUT=10s

# Shared poller tuning
POLL_TICK_INTERVAL=5s
POLL_RESCHEDULE_INTERVAL=5m
POLL_BATCH_SIZE=2
POLL_CLAIM_TTL=30s

# Receipt webhook target
# For the local development path, point this at
# `https://receipt-webhook-mock:8443/receipt-status` if you want the dispatcher
# to talk to the fake receiver.
PAYMENT_RECEIPT_WEBHOOK_URL=https://example.com/receipt-status
PAYMENT_RECEIPT_WEBHOOK_SECRET=replace-me
PAYMENT_RECEIPT_WEBHOOK_TIMEOUT=10s
PAYMENT_RECEIPT_WEBHOOK_INSECURE_SKIP_VERIFY=false

# Receipt webhook dispatcher tuning
RECEIPT_WEBHOOK_DISPATCH_INTERVAL=15s
RECEIPT_WEBHOOK_DISPATCH_BATCH_SIZE=50
RECEIPT_WEBHOOK_DISPATCH_CLAIM_TTL=30s
RECEIPT_WEBHOOK_DISPATCH_MAX_ATTEMPTS=10
RECEIPT_WEBHOOK_DISPATCH_RETRY_DELAY=1m
