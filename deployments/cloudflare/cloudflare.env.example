# Save this file as `deployments/cloudflare/cloudflare.env`.
#
# The local Cloudflare helper commands read this file:
# - `make cf-up`
#
# This file is for local deploy helpers only.
# It is not a complete runtime reference and it is not loaded by the Worker at request time.
# Leave optional values blank when you do not want `make cf-up` to sync them.

# Cloudflare CLI auth for non-interactive deploys.
# Local interactive use can rely on `wrangler login` instead.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Required Worker runtime values.
# `make cf-up` syncs both into the Worker and runs migration first.
POSTGRES_CONNECTION_STRING=postgres://user:password@host:5432/payrune?sslmode=require
PAYMENT_RECEIPT_WEBHOOK_SECRET=replace-me

# Optional Worker runtime values.
# `make cf-up` syncs any non-empty value in this section.

# Bitcoin mainnet
# Optional operator intent. Leave blank to keep the policy disabled.
BITCOIN_MAINNET_LEGACY_ENABLED=
BITCOIN_MAINNET_LEGACY_XPUB=

BITCOIN_MAINNET_SEGWIT_ENABLED=
BITCOIN_MAINNET_SEGWIT_XPUB=

BITCOIN_MAINNET_NATIVE_SEGWIT_ENABLED=
BITCOIN_MAINNET_NATIVE_SEGWIT_XPUB=

BITCOIN_MAINNET_TAPROOT_ENABLED=
BITCOIN_MAINNET_TAPROOT_XPUB=

BITCOIN_MAINNET_ESPLORA_USER=
BITCOIN_MAINNET_ESPLORA_PASSWORD=

# Bitcoin testnet4
# Optional operator intent. Leave blank to keep the policy disabled.
BITCOIN_TESTNET4_LEGACY_ENABLED=
BITCOIN_TESTNET4_LEGACY_XPUB=

BITCOIN_TESTNET4_SEGWIT_ENABLED=
BITCOIN_TESTNET4_SEGWIT_XPUB=

BITCOIN_TESTNET4_NATIVE_SEGWIT_ENABLED=
BITCOIN_TESTNET4_NATIVE_SEGWIT_XPUB=

BITCOIN_TESTNET4_TAPROOT_ENABLED=
BITCOIN_TESTNET4_TAPROOT_XPUB=

BITCOIN_TESTNET4_ESPLORA_USER=
BITCOIN_TESTNET4_ESPLORA_PASSWORD=

# Ethereum mainnet
# Optional operator intent. Leave blank to keep the policy disabled.
ETHEREUM_MAINNET_CREATE2_ENABLED=
ETHEREUM_MAINNET_USDT_CREATE2_ENABLED=

# Factory addresses and receiver init-code hashes come from checked-in metadata and artifacts.
# `*_DERIVATION_KEY` must be 32-byte hex, for example:
# 0x1111111111111111111111111111111111111111111111111111111111111111
# Required when ETHEREUM_MAINNET_CREATE2_ENABLED=true or ETHEREUM_MAINNET_USDT_CREATE2_ENABLED=true.
ETHEREUM_MAINNET_CREATE2_COLLECTOR_ADDRESS=
ETHEREUM_MAINNET_CREATE2_DERIVATION_KEY=
# Required only when ETHEREUM_MAINNET_USDT_CREATE2_ENABLED=true.
ETHEREUM_MAINNET_USDT_ASSET_REFERENCE=

# Optional provider auth.
ETHEREUM_MAINNET_RPC_USER=
ETHEREUM_MAINNET_RPC_PASSWORD=

# Ethereum sepolia
# Optional operator intent. Leave blank to keep the policy disabled.
ETHEREUM_SEPOLIA_CREATE2_ENABLED=
ETHEREUM_SEPOLIA_USDT_CREATE2_ENABLED=

# Required when ETHEREUM_SEPOLIA_CREATE2_ENABLED=true or ETHEREUM_SEPOLIA_USDT_CREATE2_ENABLED=true.
ETHEREUM_SEPOLIA_CREATE2_COLLECTOR_ADDRESS=
ETHEREUM_SEPOLIA_CREATE2_DERIVATION_KEY=
# Required only when ETHEREUM_SEPOLIA_USDT_CREATE2_ENABLED=true.
ETHEREUM_SEPOLIA_USDT_ASSET_REFERENCE=

# Optional provider auth.
ETHEREUM_SEPOLIA_RPC_USER=
ETHEREUM_SEPOLIA_RPC_PASSWORD=
