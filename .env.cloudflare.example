# Copy this file to `.env.cloudflare` at repo root.
#
# Local Cloudflare commands auto-load `.env.cloudflare`:
# - `make cf-up`
# - `make cf-migrate`
#
# `make cf-down` does not need these values, but loading the file is harmless.
# Cloudflare login is intentionally not included here; use `wrangler login`.

# Optional but recommended for non-interactive Cloudflare deploys.
# You can also rely on `wrangler login` locally.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Required values.
# Used by:
# - `make cf-up`
# - `make cf-migrate`
POSTGRES_CONNECTION_STRING=postgres://user:password@host:5432/payrune?sslmode=require

# Required webhook dispatcher / mock secret for `make cf-up`.
PAYMENT_RECEIPT_WEBHOOK_SECRET=replace-me

# Optional API Worker secrets.
# Leave blank to skip syncing that secret during `make cf-up`.
BITCOIN_MAINNET_LEGACY_XPUB=
BITCOIN_MAINNET_SEGWIT_XPUB=
BITCOIN_MAINNET_NATIVE_SEGWIT_XPUB=
BITCOIN_MAINNET_TAPROOT_XPUB=
BITCOIN_TESTNET4_LEGACY_XPUB=
BITCOIN_TESTNET4_SEGWIT_XPUB=
BITCOIN_TESTNET4_NATIVE_SEGWIT_XPUB=
BITCOIN_TESTNET4_TAPROOT_XPUB=

# Optional poller auth secrets.
# Leave blank when using public Esplora endpoints or providers without auth.
BITCOIN_MAINNET_ESPLORA_USER=
BITCOIN_MAINNET_ESPLORA_PASSWORD=
BITCOIN_TESTNET4_ESPLORA_USER=
BITCOIN_TESTNET4_ESPLORA_PASSWORD=
